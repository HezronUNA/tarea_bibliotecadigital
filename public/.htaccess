<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Si es un archivo o directorio existente, no redirigir
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Redirigir todo a index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>
