{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Iniciar Servidor PHP",
            "type": "shell",
            "command": "php",
            "args": [
                "-S",
                "localhost:8000",
                "-t",
                "public"
            ],
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Development Server",
                    "endsPattern": "listening on"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
